#!/usr/bin/env bash
# workflow-review-read — read review log and config for dashboard
# Usage: workflow-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/workflow-slug" 2>/dev/null)"
WORKFLOW_HOME="${WORKFLOW_HOME:-$HOME/.workflow}"
cat "$WORKFLOW_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/workflow-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
