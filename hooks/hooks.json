{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "安裝後請將此檔案內容合併到 ~/.claude/settings.json，並將 ${HOOKS_DIR} 替換為實際路徑",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git stash*)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cd)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(tee *)",
      "Bash(xargs *)",
      "Bash(test *)",
      "Bash([ *)",
      "Bash(export *)",
      "Bash(env *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(jq *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(basename *)",
      "Bash(dirname *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(chmod 777 *)",
      "Bash(> /dev/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/hook-router.js\""
          }
        ],
        "description": "Unified router (blocking policies: secrets/dev-server/doc-file)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/hook-router.js\""
          }
        ],
        "description": "Unified router (context monitor + console warnings)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-worker.js\" --task format",
            "async": true
          }
        ],
        "description": "Native async format worker with debounce"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-worker.js\" --task typecheck",
            "async": true
          }
        ],
        "description": "Native async typecheck worker with debounce"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/hook-router.js\""
          }
        ],
        "description": "Unified router (console audit + desktop notifications)"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "general-purpose",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review the subagent's final output. Check: (1) Did it claim completion? If so, does the output contain concrete evidence (file paths, test results, command output) — not just 'Done!' or 'All set!'? (2) Are there red flags like 'should work', 'probably', or missing verification steps? If the output lacks evidence of completion, respond with a brief note about what verification is missing. If the output contains proper evidence, respond with 'LGTM'.",
            "timeout": 30
          }
        ],
        "description": "Lightweight spec review for general-purpose subagent output"
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/hook-router.js\""
          }
        ],
        "description": "Unified router notification handling"
      }
    ]
  }
}
