{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "安裝後請將此檔案內容合併到 ~/.claude/settings.json 的 hooks 區塊，並將 ${HOOKS_DIR} 替換為實際路徑",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/dev-server-blocker.js\""
          }
        ],
        "description": "Block dev servers outside tmux"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/git-push-reminder.js\""
          }
        ],
        "description": "Reminder before git push"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/doc-file-blocker.js\""
          }
        ],
        "description": "Block creation of random .md files"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/detect-secrets.js\""
          }
        ],
        "description": "Detect and block secrets in file content"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/suggest-compact.js\""
          }
        ],
        "description": "Suggest manual compaction at logical intervals"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format JS/TS files with Prettier after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "TypeScript check after editing .ts/.tsx files"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-console-warn.js\""
          }
        ],
        "description": "Warn about console.log statements after edits"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/check-console-log.js\""
          }
        ],
        "description": "Check for console.log in modified files after each response"
      }
    ]
  }
}
