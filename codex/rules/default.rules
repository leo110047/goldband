prefix_rule(pattern=["curl", "-sS", "https://gwtliwvgtbwkvbgfacjt.supabase.co/functions/v1/photo-share-page?shareId=shr-efaf675735d642c4&format=json"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
